<UserControl x:Class="TaskbarWidget.WidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <!-- Context menu — Exit and auto-start toggle -->
        <ContextMenu x:Key="WidgetMenu">
            <MenuItem Header="Start with Windows" IsCheckable="True"/>
            <Separator/>
            <MenuItem Header="Exit TaskbarWidget"/>
        </ContextMenu>
    </UserControl.Resources>

    <!--
        Root grid is transparent so the taskbar shows through underneath.
        MouseLeftButtonDown kicks off drag via the host.
        ContextMenuOpening lets us tick/untick the auto-start item before display.
    -->
    <Grid x:Name="RootGrid"
          Background="Transparent"
          ContextMenu="{StaticResource WidgetMenu}"
          ContextMenuOpening="OnContextMenuOpening"
          MouseLeftButtonDown="OnMouseLeftButtonDown"
          Cursor="SizeAll">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>   <!-- icon -->
            <ColumnDefinition Width="*"/>      <!-- bar + label group -->
        </Grid.ColumnDefinitions>

        <!-- ── Icon / sprite ────────────────────────────────────────────── -->
        <Image x:Name="SpriteImage"
               Grid.Column="0"
               Width="21"
               Height="21"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"
               Margin="5,0,4,0"
               IsHitTestVisible="False"
               RenderOptions.BitmapScalingMode="NearestNeighbor"/>

        <!-- ── Bar + label group (shadow here so sprite is unaffected) ──── -->
        <Grid x:Name="BarGroup" Grid.Column="1" VerticalAlignment="Center">

            <Grid.Effect>
                <DropShadowEffect x:Name="DragShadow"
                                  Opacity="0"
                                  ShadowDepth="6"
                                  BlurRadius="8"
                                  Color="#000000"/>
            </Grid.Effect>

            <Grid.RenderTransform>
                <TranslateTransform x:Name="BarGroupTranslate"/>
            </Grid.RenderTransform>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>      <!-- progress track -->
                <ColumnDefinition Width="Auto"/>   <!-- percentage label -->
                <ColumnDefinition Width="5"/>      <!-- right padding -->
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>     <!-- progress bar -->
                <RowDefinition Height="Auto"/>     <!-- reset counter -->
            </Grid.RowDefinitions>

            <!-- ── Progress bar (pill shape) ──────────────────────────── -->
            <Grid Grid.Row="0" Grid.Column="0"
                  x:Name="TrackGrid"
                  VerticalAlignment="Center"
                  SizeChanged="OnTrackSizeChanged">

                <!-- Background track (empty: orange/rust) -->
                <Border CornerRadius="4"
                        Height="7"
                        Background="#DA7659"/>

                <!-- Animated fill (full: dark gray) -->
                <Border x:Name="FillBorder"
                        CornerRadius="4"
                        Height="7"
                        HorizontalAlignment="Left"
                        Width="0"
                        IsHitTestVisible="False">
                    <Border.Background>
                        <SolidColorBrush x:Name="FillBrush" Color="#2A2A2A"/>
                    </Border.Background>
                </Border>
            </Grid>

            <!-- ── Percentage label ────────────────────────────────────── -->
            <TextBlock x:Name="PercentLabel"
                       Grid.Row="0" Grid.Column="1"
                       Text="—"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="5,0,0,0"
                       MinWidth="30"
                       TextAlignment="Right"
                       IsHitTestVisible="False"/>

            <!-- ── Reset counter (below bar, track column only) ─────────── -->
            <TextBlock x:Name="ResetCounterLabel"
                       Grid.Row="1" Grid.Column="0"
                       Text=""
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#2A2A2A"
                       TextAlignment="Center"
                       Margin="0,2,0,0"
                       IsHitTestVisible="False"/>
        </Grid>

    </Grid>
</UserControl>
